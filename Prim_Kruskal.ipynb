    "\n",
    "def desenhar_vertices(coords_dict):\n",
    "    for vertice, (x, y) in coords_dict.items():\n",
    "        plt.scatter(x, y, s=90, zorder=3)\n",
    "        plt.text(\n",
    "            x,\n",
    "            y,\n",
    "            str(vertice),\n",
    "            fontsize=12,\n",
    "            verticalalignment=\"bottom\",\n",
